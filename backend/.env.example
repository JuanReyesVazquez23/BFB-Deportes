# Copia este archivo como ".env" en la carpeta backend/ y completa tus valores reales.
# NUNCA subas el archivo .env (con secretos reales) a un repositorio público.

ENV=development

# --- Base de datos PostgreSQL ---
DATABASE_URL=postgresql+psycopg2://bfb_user:bfb_password@localhost:5432/bfb_deportes

# --- Seguridad ---
# Genera una clave aleatoria única, por ejemplo con:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTA_CLAVE_POR_UNA_ALEATORIA_Y_SECRETA

# --- APIs externas ---
# MLB Stats API no requiere API key.
# balldontlie.io (NBA, fútbol y Mundial): crea una cuenta gratis en https://balldontlie.io
BALLDONTLIE_API_KEY=f22d5349-bfa9-4d9c-aa43-8e878e1738ce

# --- CORS: dominios desde los que se permite consumir la API ---
# En producción, reemplaza por el dominio real de tu frontend.
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500","http://localhost:8000"]
